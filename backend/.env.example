# 硅基流动 API Key（仅用于 OCR / PaddleOCR-VL）
# 获取地址：https://cloud.siliconflow.cn/
SILICONFLOW_API_KEY=your-api-key-here

# 大模型配置（用于自动分类兜底、结构化提取、报告生成、规范校对）
# MiniMax OpenAI 兼容协议：
#   Base URL: https://api.minimaxi.com/v1
#   Model ID: MiniMax-M2.7 或 MiniMax-M2.7-highspeed
LLM_PROVIDER=minimax
LLM_API_KEY=your-minimax-token-plan-key-here
LLM_BASE_URL=https://api.minimaxi.com/v1
LLM_MODEL=MiniMax-M2.7
LLM_CLASSIFICATION_ENABLED=true
